<!doctype html>
<html lang="{{ lang or 'en' }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ page.title }} | {{ site.title }}</title>
<link rel="stylesheet" href="/assets/style.css">
{% if site.highlight_css %}<style>{{ site.highlight_css }}</style>{% endif %}{% for t in translations %}<link rel="alternate" hreflang="{{ t.lang }}" href="{{ t.url }}">{% endfor %}
</head>
<body>
<header class="topbar">
<a href="/" class="brand">{{ site.title }}</a>
<nav><a href="/tags/">{{ t("nav.tags") }}</a> <a href="/categories/">{{ t("nav.categories") }}</a>{% for t in translations %} <a class="lang-link" hreflang="{{ t.lang }}" href="{{ t.url }}">{{ t.lang|upper }}</a>{% endfor %}</nav>
</header>
<div class="layout">
<aside class="sidebar">
{% for sec in menu %}
<div class="nav-section">
<p class="nav-section-title">{{ sec.section or t("nav.home") }}</p>
<ul>{% for item in sec['items'] %}<li><a href="{{ item.url }}">{{ item.title }}</a></li>{% endfor %}</ul>
</div>
{% endfor %}
</aside>
<main class="content">
{% block content %}{% endblock %}
</main>
</div>
{% if '<pre class="mermaid"' in content_html %}
<script type="module">
import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";
mermaid.initialize({ startOnLoad: true });
</script>
{% endif %}
</body>
</html>
