{% extends "base.html.j2" %}
{% block content %}
<nav class="breadcrumbs">
{% for crumb in breadcrumbs %}<a href="{{ crumb.url }}">{{ crumb.title }}</a>{% if not loop.last %} / {% endif %}{% endfor %}
</nav>
<article>
<h1>{{ page.title }}</h1>
{% if reading_time %}<p class="reading-time">{{ t("post.reading_time", minutes=reading_time) }}</p>{% endif %}
{% if toc %}
<details class="toc"><summary>{{ t("page.on_this_page") }}</summary>
<ul>{% for h in toc %}<li class="toc-l{{ h.level }}"><a href="#{{ h.slug }}">{{ h.text }}</a></li>{% endfor %}</ul>
</details>
{% endif %}
{{ content_html }}
{% if tags %}<p class="tags">{% for t in tags %}<a href="/tags/{{ t }}/">#{{ t }}</a> {% endfor %}</p>{% endif %}
</article>
<nav class="prevnext">
{% if prev %}<a class="prev" href="{{ prev.url }}">&larr; {{ prev.title }}</a>{% endif %}
{% if next %}<a class="next" href="{{ next.url }}">{{ next.title }} &rarr;</a>{% endif %}
</nav>
{% if backlinks %}
<aside class="backlinks"><h3>{{ t("page.linked_from") }}</h3>
<ul>{% for b in backlinks %}<li><a href="{{ b.url }}">{{ b.title }}</a></li>{% endfor %}</ul>
</aside>
{% endif %}
{% endblock %}
