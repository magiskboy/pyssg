{% extends "base.html.j2" %}
{% block content %}
<article class="markdown book-article">
  <h1>{{ page.title }}</h1>
  <p class="reading-time">{{ t("term.tagged", count=page.count) }}</p>
  <ul class="term-members">
    {% for m in page.members %}<li><a href="{{ m.url }}">{{ m.title }}</a></li>{% endfor %}
  </ul>
</article>
{% endblock %}
